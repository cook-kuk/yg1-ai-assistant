# Product source
PRODUCT_REPO_SOURCE=db

# Start ../yg1-ai-catalog-db first, then run docker compose here.
# Prefer DATABASE_URL when available.
# Example: postgresql://postgres:postgres@host.docker.internal:5432/rag_workflow
DATABASE_URL=postgresql://smart_catalog:smart_catalog@host.docker.internal:5435/smart_catalog

# Or use discrete PG* variables instead.
PGHOST=host.docker.internal
PGPORT=5435
PGDATABASE=smart_catalog
PGUSER=smart_catalog
PGPASSWORD=smart_catalog

# Recommendation query tuning
PRODUCT_QUERY_LIMIT_FILTERED=2000
PRODUCT_QUERY_LIMIT_BROAD=800
PRODUCT_DB_POOL_MAX=10
PRODUCT_DB_POOL_IDLE_MS=30000
PRODUCT_DB_CONNECT_TIMEOUT_MS=5000
LOG_RECOMMEND_TIMINGS=true

# LLM keys
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=

# ── Model Configuration ──────────────────────────────────────
# Default model (fallback for all tiers)
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_FAST_MODEL=claude-sonnet-4-20250514

# Model tier defaults (used by resolveModel in provider.ts)
ANTHROPIC_HAIKU_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_SONNET_MODEL=claude-sonnet-4-20250514
ANTHROPIC_OPUS_MODEL=claude-opus-4-0-20250415

# ── Agent-specific model overrides ────────────────────────────
# Each agent can use a different model. Leave empty to use tier default.
# Intent classifier — fast, runs every turn
AGENT_INTENT_CLASSIFIER_MODEL=
# Parameter extractor — fast, runs on SET_PARAMETER/SELECT_OPTION
AGENT_PARAMETER_EXTRACTOR_MODEL=
# Comparison agent — needs reasoning
AGENT_COMPARISON_MODEL=
# Response composer — needs natural language quality
AGENT_RESPONSE_COMPOSER_MODEL=
# Ambiguity resolver — needs deep reasoning (escalation only)
AGENT_AMBIGUITY_RESOLVER_MODEL=

# Docker compose host port
APP_PORT=3001
