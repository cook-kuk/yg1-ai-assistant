{
  "name": "flute_replace_after_recommendation",
  "description": "fluteCount 동일 필드 교체 — 2날 → 4날",
  "severity": "critical",
  "initial": { "language": "ko" },
  "turns": [
    {
      "input": "알루미늄 Square 2날 직경 10 추천해줘",
      "expect": {
        "stateContains": [
          { "field": "toolSubtype", "op": "includes", "value": "Square" },
          { "field": "fluteCount", "op": "eq", "value": 2 },
          { "field": "diameterMm", "op": "eq", "value": 10 }
        ],
        "candidateCount": { "min": 1 },
        "topCard": { "exists": true }
      }
    },
    {
      "input": "2날 말고 4날로",
      "expect": {
        "stateContains": [
          { "field": "fluteCount", "op": "eq", "value": 4 }
        ],
        "stateNotContains": [
          { "field": "fluteCount", "op": "eq", "value": 2 }
        ]
      }
    }
  ]
}
