{
  "name": "range_request",
  "description": "직경 범위 요청 (10 이상) → 동일 필드 eq를 gte로 교체",
  "severity": "normal",
  "initial": { "language": "ko" },
  "turns": [
    {
      "input": "알루미늄 Square 2날 직경 10 추천해줘",
      "expect": {
        "stateContains": [
          { "field": "diameterMm", "op": "eq", "value": 10 },
          { "field": "toolSubtype", "op": "includes", "value": "Square" }
        ],
        "candidateCount": { "min": 1 }
      }
    },
    {
      "input": "직경 10 이상",
      "expect": {
        "stateContains": [
          { "field": "diameterMm", "op": "gte", "value": 10 }
        ],
        "stateNotContains": [
          { "field": "diameterMm", "op": "eq", "value": 10 }
        ]
      }
    }
  ]
}
