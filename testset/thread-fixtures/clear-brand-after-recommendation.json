{
  "name": "clear_brand_after_recommendation",
  "description": "브랜드 필터 clear ('상관없음') 처리",
  "severity": "normal",
  "initial": { "language": "ko" },
  "turns": [
    {
      "input": "알루미늄 Square 2날 직경 10 CRX S로 추천해줘",
      "expect": {
        "stateContains": [
          { "field": "brand", "op": "includes", "value": "CRX S" },
          { "field": "fluteCount", "op": "eq", "value": 2 }
        ]
      }
    },
    {
      "input": "브랜드는 상관없음",
      "expect": {
        "stateNotContains": [
          { "field": "brand", "op": "includes", "value": "CRX S" }
        ]
      }
    }
  ]
}
