#!/usr/bin/env bash
# pre-push hook: README 상단 metric 블록을 reports/latest-metrics.xlsx 기준으로 갱신.
# 변경이 있으면 push 를 중단하고 사용자가 확인 후 다시 push 하게 함.
set -e
ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT"
if [ ! -f reports/latest-metrics.xlsx ]; then
  echo "[pre-push] reports/latest-metrics.xlsx 없음 — metric 갱신 skip"
  exit 0
fi
node scripts/update-readme-metrics.js || {
  echo "[pre-push] metric 갱신 실패"
  exit 1
}
if ! git diff --quiet README.md; then
  echo "[pre-push] README metric 블록이 갱신됐습니다. 확인 후 다시 커밋/푸시 해주세요."
  git --no-pager diff --stat README.md
  exit 1
fi
exit 0
