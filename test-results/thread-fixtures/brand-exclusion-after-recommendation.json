{
  "name": "brand_exclusion_after_recommendation",
  "description": "추천 후 브랜드 제외(CRX S 가 아닌걸로)가 state/DB/UI에 반영되는지",
  "severity": "critical",
  "initial": { "language": "ko" },
  "turns": [
    {
      "input": "알루미늄 Square 2날 직경 10 추천해줘",
      "expect": {
        "stateContains": [
          { "field": "toolSubtype", "op": "includes", "value": "Square" },
          { "field": "fluteCount", "op": "eq", "value": 2 },
          { "field": "diameterMm", "op": "eq", "value": 10 }
        ],
        "candidateCount": { "min": 1 },
        "topCard": { "exists": true }
      }
    },
    {
      "input": "CRX S 가 아닌걸로",
      "expect": {
        "stateNotContains": [
          { "field": "brand", "op": "eq", "value": "CRX S" }
        ],
        "forbiddenBrands": ["CRX S"],
        "topCard": { "exists": true, "forbiddenBrands": ["CRX S"] }
      }
    }
  ]
}
