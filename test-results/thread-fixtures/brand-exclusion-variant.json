{
  "name": "brand_exclusion_variant",
  "description": "'CRX S 말고 다른 브랜드' 변형 negation 패턴 처리",
  "severity": "critical",
  "initial": { "language": "ko" },
  "turns": [
    {
      "input": "주철 Square 4날 직경 6 추천해줘",
      "expect": {
        "stateContains": [
          { "field": "toolSubtype", "op": "includes", "value": "Square" },
          { "field": "fluteCount", "op": "eq", "value": 4 },
          { "field": "diameterMm", "op": "eq", "value": 6 }
        ],
        "candidateCount": { "min": 1 },
        "topCard": { "exists": true }
      }
    },
    {
      "input": "CRX S 말고 다른 브랜드",
      "expect": {
        "stateNotContains": [
          { "field": "brand", "op": "eq", "value": "CRX S" }
        ],
        "forbiddenBrands": ["CRX S"],
        "topCard": { "exists": true, "forbiddenBrands": ["CRX S"] }
      }
    }
  ]
}
