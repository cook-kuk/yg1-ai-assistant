{
  "name": "go_back_then_exclude_brand",
  "description": "이전으로 돌아간 후 브랜드 제외 — undo + negation 결합",
  "severity": "normal",
  "initial": { "language": "ko" },
  "turns": [
    {
      "input": "주철 Square 4날 직경 6 추천해줘",
      "expect": {
        "stateContains": [
          { "field": "fluteCount", "op": "eq", "value": 4 }
        ],
        "candidateCount": { "min": 1 },
        "topCard": { "exists": true }
      }
    },
    {
      "input": "이전으로 돌아가서 CRX S 제외",
      "expect": {
        "stateNotContains": [
          { "field": "brand", "op": "eq", "value": "CRX S" }
        ],
        "forbiddenBrands": ["CRX S"]
      }
    }
  ]
}
